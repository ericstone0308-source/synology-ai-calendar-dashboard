# =========================================================================
# Antigravity Dashboard Environment Configuration Template
# Copy this file to '.env' and fill in your actual credentials.
# =========================================================================

# --- Notion Integration (For fetching your notes page) ---
NOTION_API_KEY=your_notion_integration_token_here
NOTION_PAGE_ID=your_notion_page_uuid_here

# --- Google Gemini API (For generating your AI Cognitive Report) ---
# Get your free API Key from: https://aistudio.google.com/
GEMINI_API_KEY=your_gemini_api_key_here
